# Copy to .env and fill in real values. .env is gitignored (see .gitignore).

# --- LLM (OpenRouter free model: tencent/hy3:free) ---
# Get key from https://openrouter.ai/keys
LLM_API_KEY=

# Optional overrides (defaults shown):
# LLM_MODEL=tencent/hy3:free
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Hikvision device (master branch test defaults shown) ---
# Override for online scenario; test scenario uses defaults in
# configs/door_restart_stability.yaml
# BURNIN_HOST=192.168.3.33
# BURNIN_USER=admin
# BURNIN_PASSWORD=121212..

# --- Strategy instruction (natural language for LLM to parse) ---
# Example: "skip reboot, add 2s event wait, allow time_sync heal"
# BURNIN_STRATEGY=
